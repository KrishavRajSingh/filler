# Filler — environment variables.
# Copy this file to .env and fill in real values for local dev.
# .env is git-ignored and never shipped with the extension build.

# OpenAI API key used by the Next.js /api/fill route (Plan B).
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional: override the default model (gpt-4o-mini).
# FILLER_MODEL=gpt-4o-mini

# Chrome Web Store listing URL for the landing page install CTA.
# Leave unset before launch — buttons scroll to the waitlist instead.
# NEXT_PUBLIC_CHROME_STORE_URL=https://chrome.google.com/webstore/detail/filler/your-extension-id

# Public site URL for canonical links, Open Graph, and sitemap.
# NEXT_PUBLIC_SITE_URL=https://filler.live

# Umami analytics — page views + custom events (free on Vercel Hobby).
# Sign up at https://cloud.umami.is, add filler.live, copy the website ID.
# NEXT_PUBLIC_UMAMI_WEBSITE_ID=your-website-id
# Optional if self-hosting Umami instead of Umami Cloud:
# NEXT_PUBLIC_UMAMI_URL=https://your-umami-instance.com

# Extension fill API URL is set per mode in committed env files:
#   .env.development → http://localhost:1947/api/fill  (plasmo dev)
#   .env.production  → https://filler.live/api/fill    (plasmo build)
# Override either in .env.local if needed.
